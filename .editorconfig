# EditorConfig helps maintain consistent coding styles.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
# Keep markdown tables readable
trim_trailing_whitespace = false

[*.py]
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4
