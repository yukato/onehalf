{
  "name": "bachelor-chat-bot",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "./start-dev.sh",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,css,md}'",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,css,md}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0"
  }
}
