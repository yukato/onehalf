# Zendesk API
ZENDESK_SUBDOMAIN=helpcenter.bachelorapp.net
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-api-token

# Basic認証（必須）
BASIC_AUTH_USERNAME=bachelor
BASIC_AUTH_PASSWORD=your-password

# Database URL (for Prisma)
# Local development (no password): mysql://onehalf@localhost:3307/onehalf
# AWS RDS: mysql://onehalf:PASSWORD@your-rds-endpoint:3306/onehalf
DATABASE_URL=mysql://onehalf@localhost:3307/onehalf
